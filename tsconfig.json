{
  "include": ["src/**/*.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "outDir": "dist",
    "module": "commonjs",
    "target": "es2016",
    "strict": true,
    "lib": ["es2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@app/*": ["./src/application/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@__utils__/*": ["./src/__utils__/*"]
    }
  }
}
