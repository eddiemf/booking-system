{
  "include": ["src/**/*.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ES2023",
    "strict": true,
    "lib": ["ES2023"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "@app/*": ["./src/application/*"],
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@__utils__/*": ["./src/__utils__/*"]
    }
  }
}
